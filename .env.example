# Bitrix24 API Configuration
# Скопируйте этот файл в .env и заполните своими данными

BITRIX24_WEBHOOK=https://online-kassa.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/
BITRIX24_DOMAIN=online-kassa.bitrix24.ru
BITRIX24_SOURCE_IP=

# Bit.Newton ASR
BITNEWTON_ASR_URL=https://bit-asr.1bitai.ru
BITNEWTON_TOKEN=your_bitnewton_token

# VibeCode Bitrix24 API (optional)
VIBECODE_API_KEY=your_vibecode_api_key
VIBECODE_TIMEOUT_SEC=30
VIBECODE_MAX_ATTEMPTS=3
VIBECODE_SOURCE_IP=
